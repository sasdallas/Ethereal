include ../../make.config

CFLAGS?=-O2 -g
CPPFLAGS?=
LDFLAGS?=
LIBS?=

DESTDIR?=
PREFIX?=/usr
EXEC_PREFIX?=$(PREFIX)
BOOT_OUTPUT?=/boot
INCLUDE_DIR?=$(PREFIX)/include
LIBDIR?=$(EXEC_PREFIX)/lib

LIBDIRS = $(dir $(shell $(CC) -print-libgcc-file-name))

CFLAGS := $(CFLAGS) -D__KERNEL__ -ffreestanding
CPPFLAGS := $(CPPFLAGS) -D__KERNEL__ -ffreestanding
LDFLAGS := $(LDFLAGS) -L$(LIBDIRS)
LIBS := $(LIBS) -lgcc